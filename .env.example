# Memora Connect 环境变量配置

# ==================== 数据库配置 ====================
# 数据库文件路径
DATABASE_PATH=./data/memora.db

# 备份目录
DATABASE_BACKUP_PATH=./data/backups

# 最大备份数量
DATABASE_MAX_BACKUPS=10

# 自动备份间隔（秒）
DATABASE_BACKUP_INTERVAL=3600

# ==================== 存储配置 ====================
# 资产存储目录
ASSETS_PATH=./data/assets

# 最大文件大小（字节），默认100MB
MAX_FILE_SIZE=104857600

# ==================== 服务器配置 ====================
# 监听地址
SERVER_HOST=0.0.0.0

# 监听端口
SERVER_PORT=8352

# 工作进程数
SERVER_WORKERS=4

# 请求超时（秒）
SERVER_TIMEOUT=30

# ==================== 安全配置 ====================
# 访问令牌（留空则不需要认证）
ACCESS_TOKEN=

# API速率限制（请求/分钟）
RATE_LIMIT=100

# CORS允许的源（逗号分隔）
CORS_ORIGINS=*

# ==================== 日志配置 ====================
# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=./logs/app.log

# ==================== 监控配置 ====================
# 是否启用监控
MONITORING_ENABLED=true

# 健康检查间隔（秒）
HEALTH_CHECK_INTERVAL=60

# 指标保留天数
METRICS_RETENTION_DAYS=30
